# Project root is not the app document root.
# Do not externally redirect with a relative "public/" target on Windows —
# Apache turns that into http://localhost/C:/xampp/... (403).
# DirectoryIndex hits index.php, which redirects to /hms/public/.

DirectoryIndex index.php
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block sensitive / non-public paths
    RewriteRule ^\.env - [F,L]
    RewriteRule ^(app|config|db|storage|scripts|vendor|context|docs|tests|node_modules)/ - [F,L]
</IfModule>
