# HMS environment example
# Copy to .env and adjust. Never commit a real .env file.
#
# Local XAMPP: keep APP_ENV=local and APP_DEBUG=true
# Production: copy values from .env.production.example and set strong secrets

APP_NAME="Hotel Management System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/hms/public
APP_KEY=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hms
DB_USERNAME=root
DB_PASSWORD=

SESSION_LIFETIME=120
# Set true when serving over HTTPS (or rely on https:// APP_URL)
SESSION_SECURE=false
# Set true only behind a trusted reverse proxy that sets X-Forwarded-Proto
TRUST_PROXY=false

CURRENCY=GHS
TAX_RATE=0.125
TIMEZONE=Africa/Accra

# Bootstrap system admin (Owner). Run: php scripts/ensure_system_admin.php
# SYSTEM_ADMIN_NAME=System Admin
# SYSTEM_ADMIN_EMAIL=admin@example.com
# SYSTEM_ADMIN_PASSWORD=change-me

# Optional absolute path to mysqldump (defaults to XAMPP / PATH lookup)
# MYSQLDUMP_PATH=C:\xampp\mysql\bin\mysqldump.exe
