# HMS environment example
# Copy to .env and adjust for your local MySQL / XAMPP setup.
# Never commit a real .env file.

APP_NAME="Hotel Management System"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/hms/public
APP_KEY=changeme-to-a-long-random-string

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hms
DB_USERNAME=root
DB_PASSWORD=

SESSION_LIFETIME=120
CURRENCY=GHS
TAX_RATE=0.125
TIMEZONE=Africa/Accra

# Optional absolute path to mysqldump (defaults to XAMPP / PATH lookup)
# MYSQLDUMP_PATH=C:\xampp\mysql\bin\mysqldump.exe
