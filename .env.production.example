# Production environment template
# Copy to .env on the server and fill in real values. Never commit .env.

APP_NAME="Hotel Management System"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-hotel-domain.com
APP_KEY=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hms
DB_USERNAME=hms_app
DB_PASSWORD=replace-with-strong-password

SESSION_LIFETIME=120
SESSION_SECURE=true
# Enable only if TLS terminates at a reverse proxy (nginx, Cloudflare, load balancer)
TRUST_PROXY=false

CURRENCY=GHS
TAX_RATE=0.20
TIMEZONE=Africa/Accra

# Bootstrap system admin (Owner). Run after seed: php scripts/ensure_system_admin.php
SYSTEM_ADMIN_NAME=System Admin
SYSTEM_ADMIN_EMAIL=admin@example.com
SYSTEM_ADMIN_PASSWORD=change-me-strong-password

# MYSQLDUMP_PATH=/usr/bin/mysqldump
